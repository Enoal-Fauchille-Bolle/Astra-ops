{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "automerge": false,
    "packageRules": [
        {
            "description": "Exclude private GHCR images",
            "matchDatasources": [
                "docker"
            ],
            "matchPackagePatterns": [
                "ghcr\\.io/enoal-fauchille-bolle/.*"
            ],
            "enabled": false
        }
    ],
    "docker-compose": {
        "fileMatch": [
            "docker/.*/docker-compose\\.yml$"
        ]
    },
    "helm-values": {
        "fileMatch": [
            "k3s/.*/values\\.yaml$"
        ]
    },
    "kubernetes": {
        "fileMatch": [
            "k3s/.*\\.(yaml|yml)$"
        ]
    }
}
