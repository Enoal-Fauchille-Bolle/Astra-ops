{
    "$schema": "https://docs.renovatebot.com/renovate-schema.json",
    "extends": [
        "config:recommended"
    ],
    "automerge": false,
    "packageRules": [
        {
            "description": "Exclude private GHCR images",
            "matchDatasources": [
                "docker"
            ],
            "enabled": false,
            "matchPackageNames": [
                "/ghcr\\.io/enoal-fauchille-bolle/.*/"
            ]
        }
    ],
    "docker-compose": {
        "managerFilePatterns": [
            "/docker/.*/docker-compose\\.yml$/"
        ]
    },
    "helm-values": {
        "managerFilePatterns": [
            "/k3s/.*/values\\.yaml$/"
        ]
    },
    "kubernetes": {
        "managerFilePatterns": [
            "/k3s/.*\\.(yaml|yml)$/"
        ]
    }
}
